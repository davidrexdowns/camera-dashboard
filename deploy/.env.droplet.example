# k3s-control droplet — copy to /opt/camera_dashboard/.env

# Public site
PUBLIC_BASE_URL=https://gizzagawk.com

# Pi SSH over NetBird (camera on/off)
PI4_2_HOST=100.103.113.117
PI4_3_HOST=100.103.175.87

# edge-1 storage (frames only — overlay)
STORAGE_BASE_URL=http://100.103.209.30:8080
PI4_2_LATEST_PATH=latest/pi4-2.jpg
PI4_3_LATEST_PATH=latest/pi4-3.jpg
USE_EDGE_STORAGE=true

# Dashboard login (browser prompt). Generate: openssl rand -base64 24
DASHBOARD_USERNAME=david
DASHBOARD_PASSWORD=change-me-to-a-long-random-password

# Dataset upload to edge-1 (SSH/rsync over NetBird)
STORAGE_SSH_HOST=100.103.209.30
STORAGE_SSH_USER=david
STORAGE_LAN_HOST=192.168.3.11
STORAGE_DATASETS_DIR=/data/frames/datasets
RELAY_PI=pi4-2
DATASET_LOCAL_DIR=/opt/camera_dashboard/data/datasets
